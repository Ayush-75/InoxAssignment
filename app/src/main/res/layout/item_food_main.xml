<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="100dp"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/imageContainer"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivFood"
            android:src="@drawable/m3_split_button_chevron_avd"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedImage12dp" />

        <ImageView
            android:id="@+id/ivFoodType"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="4dp"
            android:background="@android:color/white"
            android:padding="1dp"
            android:src="@drawable/ic_veg" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvFoodName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Popcorn Cheese\nRegular"
        android:textColor="#111111"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/quantityContainer"
        app:layout_constraintStart_toEndOf="@id/imageContainer"
        app:layout_constraintTop_toTopOf="@id/imageContainer" />

    <TextView
        android:id="@+id/tvPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹500"
        app:layout_constraintTop_toBottomOf="@id/tvFoodName"
        android:textColor="#555555"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@id/imageContainer"
        app:layout_constraintStart_toStartOf="@id/tvFoodName" />

    <FrameLayout
        android:id="@+id/quantityContainer"
        android:layout_width="72dp"
        android:layout_height="30dp"
        app:layout_constraintBottom_toBottomOf="@id/tvFoodName"
        app:layout_constraintTop_toTopOf="@id/tvFoodName"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ADD Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Add"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textColor="#222222"
            app:cornerRadius="5dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DCA100"
            android:backgroundTint="#FFFFFF"/>

        <!-- Premium Counter using Vector ImageButtons -->
        <LinearLayout
            android:id="@+id/layoutCounter"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_counter_yellow"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- Minus Image Button -->
            <ImageButton
                android:id="@+id/btnMinus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_remove"
                android:padding="4dp"
                app:tint="@color/black" />

            <!-- Quantity Text -->
            <TextView
                android:id="@+id/tvCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Plus Image Button -->
            <ImageButton
                android:id="@+id/btnPlus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add"
                android:padding="4dp"
                app:tint="@color/black" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tvCustomizable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="customisable"
        android:textColor="#999999"
        android:textSize="9sp"
        app:layout_constraintEnd_toEndOf="@id/quantityContainer"
        app:layout_constraintStart_toStartOf="@id/quantityContainer"
        app:layout_constraintTop_toBottomOf="@id/quantityContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>